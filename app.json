{
  "expo": {
    "name": "CarParking User",
    "slug": "CarParkingUser",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1037B5"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "icon": "./assets/icon.png",
      "supportsTablet": true,
      "bundleIdentifier": "com.carparking.user",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "EstateIQ needs to access your camera to set image as profile avatar",
        "NSPhotoLibraryUsageDescription": "EstateIQ needs to access your photo library to set image as profile avatar",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.carparking.user",
      "versionCode": 1,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "9b8044aa-b66f-475d-b279-63f201642d82"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0,
      "channel": "production"
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "EstateIQ needs to access your camera to set image as profile avatar",
          "cameraPermission": "EstateIQ needs to access your photo library to set image as profile avatar"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "enableProguardInReleaseBuilds": true,
            "enableMinifyInReleaseBuilds": true
          }
        }
      ],
      "expo-font"
    ]
  }
}
